---
import { SITE, NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <span class="brand-mark">W</span>
      <span class="brand-text">
        <strong>Watsons</strong> Interiors
        <small>{SITE.tagline}</small>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="main-nav" aria-label="Primary">
      <ul>
        {NAV.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(245, 241, 235, 0.92);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--c-line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 70px;
  }
  .brand { display: flex; align-items: center; gap: 0.7rem; text-decoration: none; color: var(--c-text); }
  .brand-mark {
    width: 42px; height: 42px;
    display: grid; place-items: center;
    background: var(--c-accent); color: #fff;
    font-family: var(--font-head); font-weight: 700; font-size: 1.4rem;
    border-radius: 12px;
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1.1; font-family: var(--font-head); font-size: 1.2rem; }
  .brand-text strong { font-weight: 700; }
  .brand-text small { font-family: var(--font-body); font-size: 0.66rem; letter-spacing: 0.05em; color: var(--c-muted); text-transform: uppercase; }

  .main-nav ul { display: flex; gap: 1.4rem; list-style: none; margin: 0; padding: 0; }
  .main-nav a {
    color: var(--c-text); font-weight: 500; font-size: 0.95rem;
    text-decoration: none; padding: 0.3rem 0; border-bottom: 2px solid transparent;
  }
  .main-nav a:hover, .main-nav a[aria-current='page'] { border-bottom-color: var(--c-accent); }

  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 900px) {
    .nav-burger {
      display: flex; flex-direction: column; gap: 5px;
      width: 40px; height: 40px; justify-content: center; align-items: center;
      cursor: pointer; border-radius: 10px;
    }
    .nav-burger span { width: 22px; height: 2px; background: var(--c-text); transition: 0.2s; }
    .main-nav {
      position: absolute; top: 100%; left: 0; right: 0;
      background: var(--c-bg); border-bottom: 1px solid var(--c-line);
      max-height: 0; overflow: hidden; transition: max-height 0.3s ease;
    }
    .main-nav ul { flex-direction: column; gap: 0; padding: 0.5rem var(--space); }
    .main-nav li { border-bottom: 1px solid var(--c-line); }
    .main-nav a { display: block; padding: 0.85rem 0; }
    .nav-toggle:checked ~ .main-nav { max-height: 80vh; }
  }
</style>
