---
import { SITE } from '../consts';
interface Crumb { label: string; href?: string; }
interface Props { items: Crumb[]; }
const { items } = Astro.props;

// JSON-LD BreadcrumbList for rich results.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [{ label: 'Home', href: '/' }, ...items].map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: c.href ? new URL(c.href, SITE.url).toString() : undefined,
  })),
};
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    {items.map((c) => (
      <li>
        {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style>
  .breadcrumbs ol { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem; padding: 0; margin: 0; font-size: 0.84rem; color: var(--c-muted); }
  .breadcrumbs li:not(:first-child)::before { content: '/'; margin-right: 0.4rem; color: var(--c-line); }
  .breadcrumbs a { color: var(--c-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--c-accent-dark); text-decoration: underline; }
  .breadcrumbs span { color: var(--c-text); }
</style>
