---
import { SITE, CATEGORIES } from '../consts';
const year = new Date().getFullYear();
const rooms = CATEGORIES.filter((c) => c.group === 'room');
const more = CATEGORIES.filter((c) => c.group !== 'room');
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-about">
      <a href="/" class="footer-brand"><strong>Watsons</strong> Interiors</a>
      <p>{SITE.description}</p>
      <div class="socials">
        <a href={SITE.social.pinterest} rel="me noopener" target="_blank">Pinterest</a>
        <a href={SITE.social.instagram} rel="me noopener" target="_blank">Instagram</a>
        <a href={SITE.social.facebook} rel="me noopener" target="_blank">Facebook</a>
      </div>
    </div>

    <div class="footer-col">
      <h3>Rooms</h3>
      <ul>
        {rooms.map((c) => <li><a href={`/category/${c.slug}`}>{c.name}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Explore</h3>
      <ul>
        {more.map((c) => <li><a href={`/category/${c.slug}`}>{c.name}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h3>About</h3>
      <ul>
        <li><a href="/about">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/authors/watsons-team">Our Team</a></li>
        <li><a href="/blog">All Articles</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Legal</h3>
      <ul>
        <li><a href="/privacy-policy">Privacy Policy</a></li>
        <li><a href="/terms">Terms &amp; Conditions</a></li>
        <li><a href="/disclaimer">Disclaimer</a></li>
        <li><a href="/sitemap-index.xml">Sitemap</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} {SITE.name}. All rights reserved. Made in Australia 🇦🇺</p>
    <p class="fineprint">
      We may earn a commission from links on this site. See our
      <a href="/disclaimer">disclaimer</a>.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-accent-dark);
    color: #e9e4d8;
    padding-top: 3rem;
    margin-top: 2rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
  }
  .footer-brand { font-family: var(--font-head); font-size: 1.4rem; color: #fff; text-decoration: none; }
  .footer-brand strong { font-weight: 700; }
  .footer-about p { color: #cfc9ba; font-size: 0.95rem; max-width: 34ch; margin-top: 0.8rem; }
  .socials { display: flex; gap: 1rem; margin-top: 1rem; }
  .socials a { color: #fff; font-size: 0.88rem; text-decoration: underline; }
  .footer-col h3 { color: #fff; font-family: var(--font-body); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.9rem; }
  .footer-col ul { list-style: none; margin: 0; padding: 0; }
  .footer-col li { margin-bottom: 0.55rem; }
  .footer-col a { color: #d6d0c2; font-size: 0.92rem; text-decoration: none; }
  .footer-col a:hover { color: #fff; text-decoration: underline; }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-block: 1.4rem;
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    font-size: 0.84rem; color: #b9b3a4;
  }
  .footer-bottom a { color: #e9e4d8; }
  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-about { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
