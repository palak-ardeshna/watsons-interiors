---
import { SITE } from '../consts';
// Reusable AdSense slot. Before approval it renders a neutral placeholder.
// After approval: set SITE.adsensePublisherId in consts.ts and pass `slot`.
interface Props { slot?: string; layout?: 'in-article' | 'display'; }
const { slot, layout = 'display' } = Astro.props;
const live = SITE.adsensePublisherId && slot;
---
<div class={`ad-slot${live ? ' is-live' : ''}`} aria-hidden={!live}>
  {live ? (
    <ins class="adsbygoogle"
      style="display:block; width:100%"
      data-ad-client={SITE.adsensePublisherId}
      data-ad-slot={slot}
      data-ad-format={layout === 'in-article' ? 'fluid' : 'auto'}
      data-ad-layout={layout === 'in-article' ? 'in-article' : undefined}
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  ) : null}
</div>
