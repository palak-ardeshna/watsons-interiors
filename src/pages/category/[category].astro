---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Newsletter from '../../components/Newsletter.astro';
import { CATEGORIES } from '../../consts';

const catImages = import.meta.glob('../../assets/categories/*.jpg', {
  eager: true,
  import: 'default',
});

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const heroImg = catImages[`../../assets/categories/${cat.slug}.jpg`];
const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .filter((a) => a.data.category === cat.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${cat.name} Ideas`,
  description: cat.description,
};
---
<BaseLayout title={`${cat.name} Ideas & Guides`} description={cat.description} schema={schema}>
  <header class="cat-hero section">
    <div class="container cat-hero__inner">
      <div class="cat-hero__copy">
        <Breadcrumbs items={[{ label: cat.name }]} />
        <p class="eyebrow">{cat.name}</p>
        <h1>{cat.name} Ideas &amp; Guides</h1>
        <p class="cat-intro">{cat.description}</p>
      </div>
      {heroImg && (
        <div class="cat-hero__art">
          <Image src={heroImg} alt={`${cat.name} inspiration`}
            widths={[500, 800]} sizes="(max-width: 820px) 100vw, 440px" fetchpriority="high" />
        </div>
      )}
    </div>
  </header>

  <section class="section" style="padding-top:0">
    <div class="container">
      {articles.length > 0 ? (
        <div class="grid grid--3">
          {articles.map((a, i) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${a.id}`}
              category={a.data.category}
              pubDate={a.data.pubDate}
              readingTime={a.data.readingTime}
              coverAlt={a.data.coverAlt}
              cover={a.data.cover}
              loading={i < 3 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
      ) : (
        <p class="empty">New {cat.name.toLowerCase()} articles are on the way — check back soon.</p>
      )}
    </div>
  </section>

  <Newsletter />
</BaseLayout>

<style>
  .cat-hero { padding-bottom: 1.5rem; }
  .cat-hero__inner { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .cat-hero__copy { align-self: center; }
  .cat-intro { font-size: 1.15rem; color: var(--c-muted); max-width: 50ch; margin-bottom: 0; }
  .cat-hero__art :global(img) { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow); aspect-ratio: 3 / 2; object-fit: cover; }
  @media (max-width: 820px) { .cat-hero__inner { grid-template-columns: 1fr; } .cat-hero__art { order: -1; } }
  .empty { color: var(--c-muted); font-size: 1.1rem; }
</style>
