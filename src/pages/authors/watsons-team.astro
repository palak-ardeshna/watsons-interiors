---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE } from '../../consts';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'The Watsons Interiors Team',
  url: `${SITE.url}/authors/watsons-team`,
  worksFor: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  knowsAbout: ['Interior Design', 'Home Decor', 'DIY', 'Furniture', 'Home Organisation'],
};
---
<BaseLayout title="The Watsons Interiors Team" description="Meet the editorial team behind Watsons Interiors — Australia's practical home design resource." schema={schema}>
  <section class="section">
    <div class="container container--narrow prose">
      <Breadcrumbs items={[{ label: 'Authors', href: '/about' }, { label: 'Watsons Interiors Team' }]} />
      <div class="author-head">
        <div class="author-avatar-lg" aria-hidden="true">W</div>
        <div>
          <h1>The Watsons Interiors Team</h1>
          <p class="role">Editorial Team · Watsons Interiors</p>
        </div>
      </div>

      <p class="lede">We're a small team of Australian writers, stylists and home-design
      enthusiasts who believe great interiors should be practical and achievable.</p>

      <h2>Our background</h2>
      <p>Between us we've renovated apartments, styled rentals, assembled more flat-pack
      furniture than we'd like to admit, and spent years reading, testing and writing about
      home design. We bring that hands-on experience to every guide we publish.</p>

      <h2>Editorial standards</h2>
      <ul>
        <li>We research thoroughly and cite practical, real-world considerations.</li>
        <li>We update articles as trends, products and prices change.</li>
        <li>We clearly disclose any affiliate relationships — see our <a href="/disclaimer">disclaimer</a>.</li>
        <li>We welcome corrections; email us at <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</li>
      </ul>

      <h2>Areas we cover</h2>
      <p>Living rooms, bedrooms, kitchens, bathrooms, home offices, DIY decor, home
      organisation, furniture buying and Australian interior trends.</p>
    </div>
  </section>
</BaseLayout>
<style>
  .author-head { display: flex; gap: 1.2rem; align-items: center; margin: 1rem 0; }
  .author-head h1 { margin: 0; }
  .role { color: var(--c-muted); margin: 0.2rem 0 0; }
  .author-avatar-lg { width: 80px; height: 80px; flex: none; border-radius: 50%; background: var(--c-accent); color: #fff; display: grid; place-items: center; font-family: var(--font-head); font-size: 2.2rem; }
  .lede { font-size: 1.2rem; color: var(--c-muted); }
</style>
