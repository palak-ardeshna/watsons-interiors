---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE, CATEGORIES } from '../consts';
import { coverDataUri } from '../lib/cover';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = articles.find((a) => a.data.featured) ?? articles[0];
const latest = articles.filter((a) => a.id !== featured?.id).slice(0, 6);

const rooms = CATEGORIES.filter((c) => c.group === 'room');
const furniture = articles.filter((a) => a.data.category === 'furniture-guides').slice(0, 3);
const diy = articles.filter((a) => a.data.category === 'diy-decor').slice(0, 3);

const trust = [
  { icon: '🏠', title: 'Room Guides', text: 'Practical ideas for every room in the house.' },
  { icon: '🛠', title: 'DIY Projects', text: 'Budget makeovers you can do this weekend.' },
  { icon: '🪑', title: 'Furniture Advice', text: 'Honest buying guides for real budgets.' },
  { icon: '🇦🇺', title: 'Australian Design', text: 'Styles and trends made for Aussie homes.' },
];
---
<BaseLayout title={SITE.name} description={SITE.description}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Australia's home design resource hub</p>
        <h1>Transform your home with practical interior ideas</h1>
        <p class="hero-sub">
          Discover room inspiration, furniture guides, DIY projects and home styling ideas
          designed for modern Australian living.
        </p>
        <div class="hero-cta">
          <a href="/blog" class="btn btn--primary">Explore ideas →</a>
          <a href="/category/furniture-guides" class="btn btn--ghost">Furniture guides</a>
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <img src={coverDataUri(28, 'Styled Australian living room')} alt="" width="1200" height="800" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- Trust cards -->
  <section class="section trust">
    <div class="container">
      <div class="grid grid--4">
        {trust.map((t) => (
          <div class="trust-card">
            <span class="trust-icon" aria-hidden="true">{t.icon}</span>
            <h3>{t.title}</h3>
            <p>{t.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured -->
  {featured && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-head"><h2>Featured</h2><a href="/blog" class="more-link">All articles →</a></div>
        <ArticleCard
          featured
          title={featured.data.title}
          description={featured.data.description}
          href={`/articles/${featured.id}`}
          category={featured.data.category}
          pubDate={featured.data.pubDate}
          readingTime={featured.data.readingTime}
          coverAlt={featured.data.coverAlt}
          cover={featured.data.cover}
          loading="eager"
        />
      </div>
    </section>
  )}

  <!-- Browse by room -->
  <section class="section">
    <div class="container">
      <div class="section-head"><h2>Browse by room</h2></div>
      <div class="room-grid">
        {rooms.map((c) => (
          <a class="room-tile" href={`/category/${c.slug}`}>
            <img src={coverDataUri(c.hue, `${c.name} ideas`)} alt="" width="800" height="600" loading="lazy" />
            <span class="room-tile__label">{c.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest -->
  {latest.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-head"><h2>Latest articles</h2><a href="/blog" class="more-link">View all →</a></div>
        <div class="grid grid--3">
          {latest.map((a) => (
            <ArticleCard
              title={a.data.title}
              href={`/articles/${a.id}`}
              category={a.data.category}
              pubDate={a.data.pubDate}
              readingTime={a.data.readingTime}
              coverAlt={a.data.coverAlt}
              cover={a.data.cover}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- DIY + Furniture (only render if content exists) -->
  {diy.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head"><h2>DIY inspiration</h2><a href="/category/diy-decor" class="more-link">More DIY →</a></div>
        <div class="grid grid--3">
          {diy.map((a) => (
            <ArticleCard title={a.data.title} href={`/articles/${a.id}`} category={a.data.category}
              pubDate={a.data.pubDate} readingTime={a.data.readingTime} coverAlt={a.data.coverAlt} cover={a.data.cover} />
          ))}
        </div>
      </div>
    </section>
  )}

  {furniture.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-head"><h2>Furniture buying guides</h2><a href="/category/furniture-guides" class="more-link">All guides →</a></div>
        <div class="grid grid--3">
          {furniture.map((a) => (
            <ArticleCard title={a.data.title} href={`/articles/${a.id}`} category={a.data.category}
              pubDate={a.data.pubDate} readingTime={a.data.readingTime} coverAlt={a.data.coverAlt} cover={a.data.cover} />
          ))}
        </div>
      </div>
    </section>
  )}

  <Newsletter />
</BaseLayout>

<style>
  .hero { padding: clamp(2rem, 6vw, 4rem) 0; }
  .hero-inner { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(1.5rem, 5vw, 3rem); align-items: center; }
  .hero-copy h1 { margin: 0.3rem 0 0.8rem; }
  .hero-sub { font-size: 1.18rem; color: var(--c-muted); max-width: 48ch; }
  .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 1.4rem; }
  .hero-art img { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow); aspect-ratio: 3 / 2; object-fit: cover; }
  @media (max-width: 820px) { .hero-inner { grid-template-columns: 1fr; } .hero-art { order: -1; } }

  .trust-card { background: var(--c-card); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); text-align: center; }
  .trust-icon { font-size: 2rem; }
  .trust-card h3 { margin: 0.6rem 0 0.3rem; font-size: 1.15rem; }
  .trust-card p { margin: 0; color: var(--c-muted); font-size: 0.92rem; }

  .more-link { font-weight: 600; font-size: 0.92rem; }

  .room-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; }
  .room-tile { position: relative; display: block; border-radius: var(--radius); overflow: hidden; aspect-ratio: 4 / 3; box-shadow: var(--shadow); }
  .room-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .room-tile:hover img { transform: scale(1.06); }
  .room-tile__label {
    position: absolute; inset: auto 0 0 0; padding: 1.4rem 1rem 0.8rem;
    color: #fff; font-family: var(--font-head); font-size: 1.15rem; font-weight: 700;
    background: linear-gradient(to top, rgba(43,43,43,0.7), transparent);
  }
</style>
