---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AdSlot from '../components/AdSlot.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE, CATEGORY_MAP } from '../consts';
import { coverDataUri, formatDate, readingTime as calcRT } from '../lib/cover';

const { entry } = Astro.props;
const data = entry.data;
const cat = CATEGORY_MAP[data.category];
const { Content, headings } = await render(entry);

const fallbackCover = coverDataUri(cat.hue, data.coverAlt);
// Absolute URL for the OG/schema image (real photo if present, else SVG).
const ogCover = data.cover
  ? new URL((await getImage({ src: data.cover, width: 1200 })).src, SITE.url).toString()
  : fallbackCover;
const rt = data.readingTime ?? calcRT(entry.body ?? '');
const url = new URL(`/articles/${entry.id}`, SITE.url).toString();

// Related: same category, newest first, exclude self.
const all = await getCollection('articles', ({ data }) => !data.draft);
const related = all
  .filter((a) => a.data.category === data.category && a.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  image: [ogCover],
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: data.author, url: `${SITE.url}/authors/watsons-team` },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: `${SITE.url}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  articleSection: cat.name,
};
---
<BaseLayout title={data.title} description={data.description} type="article" image={ogCover} schema={articleSchema}>
  <article class="post">
    <header class="post-header">
      <div class="container container--narrow">
        <Breadcrumbs items={[{ label: cat.name, href: `/category/${cat.slug}` }, { label: data.title }]} />
        <a href={`/category/${cat.slug}`} class="badge post-cat">{cat.name}</a>
        <h1>{data.title}</h1>
        <p class="post-lede">{data.description}</p>
        <div class="post-meta">
          <span>By <a href="/authors/watsons-team">{data.author}</a></span>
          <span>·</span>
          <time datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
          <span>·</span>
          <span>{rt} min read</span>
          {data.updatedDate && (
            <>
              <span>·</span>
              <span>Updated {formatDate(data.updatedDate)}</span>
            </>
          )}
        </div>
      </div>
    </header>

    <figure class="post-cover">
      {data.cover ? (
        <Image src={data.cover} alt={data.coverAlt} widths={[600, 900, 1200]}
          sizes="(max-width: 760px) 100vw, 760px" fetchpriority="high" decoding="async" />
      ) : (
        <img src={fallbackCover} alt={data.coverAlt} width="1200" height="800" fetchpriority="high" decoding="async" />
      )}
      {data.coverCredit && <figcaption class="post-cover__credit">{data.coverCredit}</figcaption>}
    </figure>

    <AdSlot layout="display" />

    <div class="container container--narrow">
      <div class="prose post-body">
        <Content />
      </div>

      <AdSlot layout="in-article" />

      {data.tags.length > 0 && (
        <ul class="post-tags" aria-label="Tags">
          {data.tags.map((t) => <li>#{t}</li>)}
        </ul>
      )}

      <aside class="author-box">
        <div class="author-avatar" aria-hidden="true">W</div>
        <div>
          <p class="author-name">{data.author}</p>
          <p class="author-bio">
            Our editorial team researches and tests practical interior ideas for real
            Australian homes and budgets. <a href="/authors/watsons-team">Meet the team →</a>
          </p>
        </div>
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-head"><h2>More {cat.name} ideas</h2></div>
        <div class="grid grid--3">
          {related.map((a) => (
            <ArticleCard
              title={a.data.title}
              href={`/articles/${a.id}`}
              category={a.data.category}
              pubDate={a.data.pubDate}
              readingTime={a.data.readingTime}
              coverAlt={a.data.coverAlt}
              cover={a.data.cover}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <Newsletter />
</BaseLayout>

<style>
  .post-header { padding-top: 1.6rem; }
  .post-cat { margin-bottom: 0.8rem; }
  .post-header h1 { margin: 0.6rem 0 0.6rem; }
  .post-lede { font-size: 1.18rem; color: var(--c-muted); margin-bottom: 1rem; }
  .post-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 0.9rem; color: var(--c-muted); align-items: center; }
  .post-cover { margin: 1.6rem 0 0; max-width: var(--maxw); margin-inline: auto; padding-inline: var(--space); }
  .post-cover :global(img) { width: 100%; border-radius: var(--radius-lg); aspect-ratio: 3 / 2; object-fit: cover; }
  .post-cover__credit { font-size: 0.78rem; color: var(--c-muted); margin-top: 0.5rem; text-align: right; }
  .post-body { margin-top: 1.4rem; }
  .post-tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; margin: 2rem 0; }
  .post-tags li { background: var(--c-bg-2); color: var(--c-muted); font-size: 0.82rem; padding: 0.3rem 0.8rem; border-radius: 100px; }
  .author-box {
    display: flex; gap: 1rem; align-items: flex-start;
    background: var(--c-bg-2); border-radius: var(--radius); padding: 1.4rem;
    margin: 1.5rem 0 2.5rem;
  }
  .author-avatar {
    width: 56px; height: 56px; flex: none; border-radius: 50%;
    background: var(--c-accent); color: #fff; display: grid; place-items: center;
    font-family: var(--font-head); font-size: 1.5rem;
  }
  .author-name { font-weight: 600; margin: 0 0 0.2rem; }
  .author-bio { margin: 0; color: var(--c-muted); font-size: 0.95rem; }
</style>
