# Watsons Interiors — Apache config for Hostinger shared hosting
# Serves the static Astro build from public_html.

# --- Custom 404 page ---
ErrorDocument 404 /404.html

# --- Redirect www -> apex (canonical), force HTTPS ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  # www to non-www
  RewriteCond %{HTTP_HOST} ^www\.watsonsinteriors\.com\.au [NC]
  RewriteRule ^(.*)$ https://watsonsinteriors.com.au/$1 [L,R=301]
  # http to https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]
</IfModule>

# --- Gzip / Brotli compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml application/xml application/rss+xml
</IfModule>

# --- Cache static assets aggressively (they are content-hashed) ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# --- Hashed build assets are immutable ---
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# --- Basic security headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
